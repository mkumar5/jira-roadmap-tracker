# =============================================
# Jira Roadmap Manager — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ---------------------
# Jira Cloud Connection
# ---------------------
# Your Atlassian Cloud domain (e.g. mycompany.atlassian.net)
VITE_JIRA_HOST=your-org.atlassian.net

# Your Atlassian account email
VITE_JIRA_EMAIL=you@example.com

# Jira API token from: https://id.atlassian.com/manage-profile/security/api-tokens
VITE_JIRA_API_TOKEN=your-jira-api-token-here

# ---------------------
# Project Configuration
# ---------------------
# Comma-separated Jira project keys to track (e.g. "CORE,PLATFORM,MOBILE")
VITE_JIRA_PROJECT_KEYS=CORE,PLATFORM,MOBILE

# Hierarchy strategy — how your org maps Initiative → Deliverable → Epic → Story
# Options: JIRA_PREMIUM | PORTFOLIO | LABEL_BASED | COMPONENT_BASED
VITE_HIERARCHY_STRATEGY=LABEL_BASED

# ---------------------
# App Configuration
# ---------------------
VITE_APP_NAME=Jira Roadmap Manager

# ---------------------
# GitHub MCP (for Claude Code integration)
# ---------------------
# GitHub PAT from: https://github.com/settings/tokens
# Required scopes: repo, read:org
GITHUB_TOKEN=your-github-pat-here
